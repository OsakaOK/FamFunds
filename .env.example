# Copy this file to ".env" and fill in your real values from Supabase.
# Supabase dashboard -> Project Settings -> API
#   - "Project URL"  -> EXPO_PUBLIC_SUPABASE_URL
#   - "anon public" key -> EXPO_PUBLIC_SUPABASE_ANON_KEY
#
# The EXPO_PUBLIC_ prefix is required for Expo to load these into the app.
# After editing .env, restart the dev server with:  npx expo start --clear

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
